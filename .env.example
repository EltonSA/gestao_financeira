# Copie para .env.local (dev) ou configure no painel do host (produção).

# Caminho do SQLite (padrão: ./data/app.db relativo à raiz do projeto).
# Em produção use um caminho em disco persistente (volume); o mesmo caminho em todo deploy mantém os dados.
# DATABASE_PATH=./data/app.db

# URL pública do app (links de convite casal / filho)
# NEXT_PUBLIC_APP_URL=https://seu-dominio.com
