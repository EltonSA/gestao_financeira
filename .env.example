# Copie para .env.local (dev) ou configure no painel do host (produção).

# PostgreSQL — obrigatório (local e produção)
# Ex.: postgresql://usuario:senha@host:5432/nome_do_banco
# Supabase/Neon/Railway costumam fornecer essa URL pronta.
DATABASE_URL=postgresql://usuario:senha@localhost:5432/gestao_casal

# SSL na conexão Postgres (hosts em nuvem geralmente precisam).
# Use false em cPanel/servidor próprio se o Postgres não tiver SSL.
# DATABASE_SSL=false

# URL pública do app (links de convite casal / filho)
# NEXT_PUBLIC_APP_URL=https://seu-dominio.com
